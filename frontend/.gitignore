# ========================
# Dependencies
# ========================
node_modules/

# ========================
# Production Build
# Generated by `npm run build` — don't commit, deploy from CI instead
# ========================
build/

# ========================
# Environment Variables
# NEVER commit these — they may contain API keys or backend URLs
# ========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example committed (documents required vars without real values)
!.env.example

# ========================
# Logs
# ========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================
# Cache / temp files
# ========================
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo

# ========================
# Testing
# ========================
coverage/

# ========================
# OS-specific files
# ========================
.DS_Store
Thumbs.db
desktop.ini

# ========================
# IDE / Editor files
# ========================
.vscode/
.idea/
*.suo
*.sln
